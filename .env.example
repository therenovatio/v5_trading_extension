# Copy this file to .env for local Toncenter API keys.
# Acton loads .env automatically.
# App templates also let Vite read the TONCENTER_ variables.
# Acton uses Toncenter to access blockchain data and send messages.
# Since there's a 1 RPS limit in key-less mode, some operations require additional waiting to avoid
# exceeding the limit. We recommend obtaining a key to speed up your transactions in Acton.
# You can obtain a key in the bot at https://t.me/toncenter.
# Acton ignores HTTP_PROXY, HTTPS_PROXY, ALL_PROXY and system proxy settings by default
# to avoid macOS sandbox proxy autodetection crashes. Set ACTON_USE_PROXY=1 or
# ACTON_USE_PROXY=true if you need Acton CLI HTTP requests to use those proxies.
# Uncomment the network keys you need:
# TONCENTER_MAINNET_API_KEY="your-mainnet-key-here"
# TONCENTER_TESTNET_API_KEY="your-testnet-key-here"

# --- TradingExtension script settings (all optional; scripts prompt or default) ---
# Wallet V5 name from the acton wallet registry that owns the extension. Its key is
# the owner key: deploy stores it on-chain and the management scripts sign with it.
# W5_DEPLOYER="deployer_v5"
# Deployed extension address (printed by `acton run deploy-testnet`):
# EXT_ADDRESS="kQ..."
# Owner pubkey override, only for the emulation deploy (no --net, key registry unavailable):
# OWNER_PUBKEY="0x..."
# Order nonces are assigned on-chain and read back by trigger-order — never set by hand.

# Session key: either a raw pubkey, or a uint256 seed (hex/decimal) the scripts
# derive the keypair from. Keep seeds secret; they authorize trades. Only the
# PUBLIC key / signatures go on-chain — the seed never leaves your machine.
# Monitoring (session-status) needs only SESSION_PUBKEY, never the seed.
# SESSION_PUBKEY="0x..."
# SESSION_SEED="0x..."
# SESSION_VALID_SECS=86400
# REFRESH_WINDOW_SECS=21600      # session-status: warn to refresh when less remains

# Trigger (webservice) key: may only fire stored orders. TRIGGER_PUBKEY=0 clears it.
# TRIGGER_PUBKEY="0x..."
# TRIGGER_SEED="0x..."

# Order parameters for store-order / cancel-order / trigger-order:
# ORDER_ID=1
# ORDER_TTL_SECS=3600
# ORDER_TARGET="kQ..."           # transfer destination
# ORDER_AMOUNT=50000000          # in nanotons (50000000 = 0.05 TON)

# Immediate session trade parameters for session-trade:
# TRADE_TARGET="kQ..."
# TRADE_AMOUNT=50000000          # in nanotons

# Swap parameters for swap.tolk — one DeDust /router/swap transaction (mainnet):
# SWAP_DEST="EQ..."              # DeDust Native Vault address (from the swap response)
# SWAP_AMOUNT=1250000000         # nanotons to send (swap amount + gas)
# SWAP_PAYLOAD="te6..."          # base64 (or hex) BoC payload from the swap response
